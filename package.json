{
  "name": "alecia-presentations",
  "version": "0.1.0",
  "description": "Alecia - M&A Pitch Deck Presentation Builder for French Financial Professionals",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\" \"npm run dev:sidecar\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd server && npm run dev",
    "dev:sidecar": "cd python-sidecar && python -m uvicorn app.main:app --reload --port 8000",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "cd server && npm run build",
    "preview": "cd frontend && npm run preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "db:init": "cd server && npm run db:init",
    "db:seed": "cd server && npm run db:seed",
    "db:migrate": "cd server && npm run db:migrate",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "typecheck": "tsc --noEmit",
    "postinstall": "cd frontend && npm install && cd ../server && npm install"
  },
  "keywords": [
    "presentation",
    "pitch-deck",
    "ma",
    "powerpoint",
    "pptx",
    "react",
    "typescript",
    "alecia"
  ],
  "author": "Alecia Team",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "prettier": "^3.2.4",
    "typescript": "^5.3.3"
  },
  "workspaces": [
    "frontend",
    "server"
  ]
}
