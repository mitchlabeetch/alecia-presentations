# ===========================================
# Alecia Presentations - Configuration
# ===========================================

# Serveur
PORT=3001
NODE_ENV=development

# URL Frontend (pour CORS)
FRONTEND_URL=http://localhost:3000

# Sécurité - Mots de passe
# IMPORTANT: Changez ces valeurs en production!
APP_PIN_CODE=1234
APP_MASTER_PASSWORD=master123

# Base de données
DATABASE_PATH=./data/alecia.db

# API IA (optionnel)
OPENROUTER_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Service Docling (optionnel)
DOCLING_SIDECAR_URL=http://localhost:8000

# Upload
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=52428800
