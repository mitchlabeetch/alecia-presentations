# Convex Backend URL (Required)
VITE_CONVEX_URL=https://aleciaconvex.manuora.fr

# Sentry Error Tracking (Optional)
VITE_SENTRY_DSN=https://your-dsn@sentry.io/project

# Analytics (Optional)
VITE_ANALYTICS_ENDPOINT=

# Application Version (Auto-set by build)
VITE_APP_VERSION=2.1.0

# Node Environment
NODE_ENV=production

# Socket Server URL (Optional - for real-time collaboration)
VITE_SOCKET_URL=

# API Keys (Optional - for AI features)
VITE_OPENAI_API_KEY=